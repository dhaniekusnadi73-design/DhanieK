# BankSoal Pro production environment
NODE_ENV=production
PORT=4173

# Public app URL, for payment callback and email links
APP_URL=https://contoh-domainmu.com

# OpenAI API for AI question generation
OPENAI_API_KEY=isi_api_key_openai
OPENAI_MODEL=gpt-5.4-mini

# Database. For production, use PostgreSQL/Supabase/Neon/Railway.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/banksoal

# Payment gateway. Recommended: Midtrans or Xendit with QRIS/GoPay webhook.
PAYMENT_PROVIDER=midtrans
PAYMENT_SERVER_KEY=isi_server_key_gateway
PAYMENT_CLIENT_KEY=isi_client_key_gateway
PAYMENT_WEBHOOK_SECRET=isi_secret_webhook
MIDTRANS_IS_PRODUCTION=false
XENDIT_CALLBACK_TOKEN=isi_callback_token_xendit_jika_pakai_xendit

# Manual admin confirmation for free/manual transfer flow.
# Use a long random value in production.
ADMIN_SECRET=ganti_dengan_secret_panjang

# Email provider. Recommended: Resend, SMTP, Mailgun, or SendGrid.
EMAIL_PROVIDER=resend
EMAIL_FROM=BankSoal Pro <noreply@contoh-domainmu.com>
RESEND_API_KEY=isi_resend_api_key

# Manual receiver info shown to users if manual transfer fallback is enabled
PAYMENT_RECEIVER_NAME=Dhanie Kusnadi
PAYMENT_RECEIVER_NUMBER=085271550657
